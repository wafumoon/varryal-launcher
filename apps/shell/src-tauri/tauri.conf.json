{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Varryal Launcher",
  "version": "1.0.1",
  "identifier": "ru.varryal.launcher",
  "build": {
    "beforeDevCommand": "pnpm --dir ../ui dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --dir ../ui build",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Varryal Launcher",
        "width": 1100,
        "height": 700,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["varryal"]
      }
    }
  }
}
