{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Varryal Launcher",
  "version": "1.0.7",
  "identifier": "ru.varryal.launcher",
  "build": {
    "beforeDevCommand": "pnpm --dir ../ui dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --dir ../ui build",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Varryal Launcher",
        "width": 1280,
        "height": 800,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["varryal"]
      }
    },
    "updater": {
      "endpoints": [
        "https://launcher.varryal.ru/updates/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2QkI3RTI0QTc2NDQ3NTYKUldSV1IyU25KSDY3WnNYYkt2VSsxNU9GNzFQcUYwUG5MZjV5RmJBZDN3WGx0anZrbWRVcGVFNVgK"
    }
  }
}
